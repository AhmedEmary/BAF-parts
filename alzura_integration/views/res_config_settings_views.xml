<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_alzura" model="ir.ui.view">
        <field name="name">res.config.settings.view.alzura</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <form position="inside">
                <app string="B2B Integrations" name="alzura_integration"
                     logo="/sale_management/static/description/icon.png"
                     groups="base.group_system">

                    <block title="Alzura B2B API Credentials">

                        <!-- Connected banner: reassurance text shown only while
                             collapsed. The reveal button (custom widget) flips the
                             boolean client-side, so the rows below show/hide instantly
                             and it resets to collapsed on a fresh page open. -->
                        <setting string="Connection"
                                 invisible="alzura_token_status != 'valid' or alzura_show_credentials">
                            <div class="text-success fw-bold mb-1">
                                <i class="fa fa-check-circle me-1"/>Connected
                            </div>
                            <div class="text-muted mb-2">
                                You have an active token — no need to enter your credentials again.
                                <span invisible="not alzura_token_expiry">
                                    Valid until
                                    <field name="alzura_token_expiry" readonly="1" class="oe_inline"/>.
                                </span>
                            </div>
                            <field name="alzura_show_credentials"
                                   widget="alzura_reveal_button" nolabel="1"/>
                        </setting>

                        <!-- Credential inputs: shown when no/expired token, or when
                             the user clicked "Update credentials". -->
                        <setting string="Alzura ID"
                                 help="Your Alzura B2B account ID"
                                 invisible="alzura_token_status == 'valid' and not alzura_show_credentials">
                            <field name="alzura_id" placeholder="e.g. 12345"/>
                        </setting>

                        <setting string="Password"
                                 help="Password is never stored — used only to fetch the token"
                                 invisible="alzura_token_status == 'valid' and not alzura_show_credentials">
                            <field name="alzura_password" password="True" placeholder="Enter password"/>
                        </setting>

                        <setting string="Country"
                                 help="ISO 3166-1 alpha-2 lowercase code sent in the request header (e.g. de)"
                                 invisible="alzura_token_status == 'valid' and not alzura_show_credentials">
                            <field name="alzura_country" placeholder="de"/>
                        </setting>

                        <setting string="Get Token"
                                 invisible="alzura_token_status == 'valid' and not alzura_show_credentials">
                            <button name="action_get_alzura_token"
                                    string="Get Token"
                                    type="object"
                                    class="btn-primary"
                                    noSaveDialog="true"/>
                            <!-- Cancel re-authentication (only when a valid token
                                 already exists to fall back to). Same widget, so it
                                 shows "Cancel" here where the value is revealed. -->
                            <field name="alzura_show_credentials"
                                   widget="alzura_reveal_button" nolabel="1" class="ms-2"
                                   invisible="alzura_token_status != 'valid'"/>
                        </setting>

                    </block>

                    <block title="Orders">

                        <setting string="Fetch Orders"
                                 help="Import the latest orders from Alzura now. Also runs automatically twice a day.">
                            <button name="action_fetch_alzura_orders"
                                    string="Fetch Orders Now"
                                    type="object"
                                    class="btn-primary"
                                    invisible="alzura_token_status == 'none'"
                                    noSaveDialog="true"/>
                        </setting>

                    </block>

                    <block title="Token Status"> 

                        <setting string="Status">
                            <field name="alzura_token_status"
                                   widget="badge"
                                   decoration-success="alzura_token_status == 'valid'"
                                   decoration-warning="alzura_token_status == 'expired'"
                                   decoration-danger="alzura_token_status == 'none'"
                                   readonly="1"/>
                        </setting>

                        <setting string="Expires On">
                            <field name="alzura_token_expiry" readonly="1"/>
                        </setting>

                        <setting string="Delete Token"
                                 help="Remove the stored Alzura token">
                            <button name="action_delete_alzura_token"
                                    string="Delete Token"
                                    type="object"
                                    class="btn-secondary"
                                    confirm="Are you sure you want to delete the Alzura token?"
                                    invisible="alzura_token_status == 'none'"
                                    noSaveDialog="true"/>
                        </setting>

                    </block>
                </app>
            </form>
        </field>
    </record>
</odoo>