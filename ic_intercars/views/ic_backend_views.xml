<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ic_backend_form" model="ir.ui.view">
        <field name="name">ic.backend.form</field>
        <field name="model">ic.backend</field>
        <field name="arch" type="xml">
            <form string="Inter Cars Backend">
                <header>
                    <button name="action_test_connection"
                            string="Test Connection" type="object"
                            class="btn-primary"/>
                    <button name="action_fetch_account_info"
                            string="Fetch Account Info" type="object"
                            class="btn-secondary"/>
                    <button name="%(action_ic_csv_import_wizard)d"
                            string="Import ProductInformation CSV"
                            type="action"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Inter Cars"/></h1>
                    </div>
                    <group>
                        <group string="Vendor">
                            <field name="vendor_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                        <group string="Business Config">
                            <field name="ship_to"/>
                            <field name="delivery_method"/>
                            <field name="payment_method"/>
                            <field name="default_language"/>
                            <field name="currency_id"/>
                            <field name="market"/>
                            <field name="vat_rate_pct"/>
                            <field name="stock_cap"/>
                        </group>
                    </group>
                    <group string="OAuth2 Credentials">
                        <field name="client_id"/>
                        <field name="client_secret" password="True"/>
                        <field name="token_url" placeholder="e.g. https://auth.example.intercars.eu/oauth2/token"/>
                        <field name="base_url"/>
                    </group>
                    <group string="Token Cache (read-only)">
                        <field name="access_token" readonly="1"/>
                        <field name="token_expiry" readonly="1"/>
                    </group>
                    <group string="CSV Channel (F04217) — bulk feed, optional">
                        <field name="csv_login"/>
                        <field name="csv_password" password="True"/>
                    </group>
                    <group string="IC Account Info (live snapshot)">
                        <field name="account_info_date"/>
                        <field name="account_info" nolabel="1" colspan="2"
                               widget="ace" options="{'mode': 'json'}"
                               readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ic_backend_list" model="ir.ui.view">
        <field name="name">ic.backend.list</field>
        <field name="model">ic.backend</field>
        <field name="arch" type="xml">
            <list string="Inter Cars Backends">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="market"/>
                <field name="default_language"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_ic_backend" model="ir.actions.act_window">
        <field name="name">Inter Cars Backends</field>
        <field name="res_model">ic.backend</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ic_backend"
              name="Inter Cars"
              parent="purchase.menu_purchase_config"
              action="action_ic_backend"
              sequence="80"/>

</odoo>
