<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ic_csv_import_wizard_form" model="ir.ui.view">
        <field name="name">ic.csv.import.wizard.form</field>
        <field name="model">ic.csv.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import IC ProductInformation CSV">
                <sheet>
                    <group>
                        <field name="backend_id"/>
                        <field name="source" widget="radio"/>
                    </group>
                    <group invisible="source != 'upload'"
                           string="Upload">
                        <field name="upload_file" filename="upload_filename"/>
                        <field name="upload_filename" invisible="1"/>
                    </group>
                    <group string="Options">
                        <field name="auto_map_seeds"/>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <p><strong>Upload:</strong> paste the daily
                            <code>ProductInformation_YYYY-MM-DD.csv</code>
                            (or its <code>.zip</code>) into the file field.
                            ~350 MB uncompressed, imports in seconds via COPY.</p>
                        <p><strong>Fetch from IC:</strong> uses the CSV Login /
                            Password on the backend to pull today's file
                            directly. Walks back up to a week if today's
                            file isn't ready yet.</p>
                        <p>Existing rows are replaced — the import is a
                            full snapshot, matching IC's own model.</p>
                    </div>
                </sheet>
                <footer>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ic_csv_import_wizard" model="ir.actions.act_window">
        <field name="name">Import IC ProductInformation CSV</field>
        <field name="res_model">ic.csv.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- List/form for the cached rows so admins can browse & search -->
    <record id="view_ic_product_info_list" model="ir.ui.view">
        <field name="name">ic.product.info.list</field>
        <field name="model">ic.product.info</field>
        <field name="arch" type="xml">
            <list string="IC Products (local cache)">
                <field name="tow_kod"/>
                <field name="ic_index"/>
                <field name="tec_doc"/>
                <field name="manufacturer"/>
                <field name="short_description"/>
                <field name="barcodes"/>
            </list>
        </field>
    </record>

    <record id="view_ic_product_info_form" model="ir.ui.view">
        <field name="name">ic.product.info.form</field>
        <field name="model">ic.product.info</field>
        <field name="arch" type="xml">
            <form string="IC Product">
                <sheet>
                    <group>
                        <group>
                            <field name="tow_kod"/>
                            <field name="ic_index"/>
                            <field name="tec_doc"/>
                            <field name="tec_doc_prod"/>
                            <field name="article_number"/>
                            <field name="manufacturer"/>
                        </group>
                        <group>
                            <field name="barcodes"/>
                            <field name="custom_code"/>
                            <field name="blocked_return"/>
                            <field name="package_weight"/>
                            <field name="package_length"/>
                            <field name="package_width"/>
                            <field name="package_height"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="short_description" nolabel="1"/>
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ic_product_info_search" model="ir.ui.view">
        <field name="name">ic.product.info.search</field>
        <field name="model">ic.product.info</field>
        <field name="arch" type="xml">
            <search string="IC Products">
                <field name="tow_kod"/>
                <field name="ic_index"/>
                <field name="tec_doc"/>
                <field name="article_number"/>
                <field name="manufacturer"/>
                <field name="barcodes"/>
                <filter name="by_manufacturer" string="Manufacturer"
                        context="{'group_by':'manufacturer'}"/>
                <filter name="by_tec_doc" string="TecDoc"
                        context="{'group_by':'tec_doc'}"/>
            </search>
        </field>
    </record>

    <record id="action_ic_product_info" model="ir.actions.act_window">
        <field name="name">IC Products (cache)</field>
        <field name="res_model">ic.product.info</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ic_product_info_search"/>
    </record>

    <menuitem id="menu_ic_product_info"
              name="IC Products (cache)"
              parent="purchase.menu_purchase_config"
              action="action_ic_product_info"
              sequence="82"/>

    <menuitem id="menu_ic_csv_import"
              name="Import IC CSV"
              parent="purchase.menu_purchase_config"
              action="action_ic_csv_import_wizard"
              sequence="81"/>

</odoo>
