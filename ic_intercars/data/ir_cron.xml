<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cron_ic_reconcile_deliveries" model="ir.cron">
        <field name="name">Inter Cars: Reconcile Deliveries</field>
        <field name="model_id" ref="model_ic_backend"/>
        <field name="state">code</field>
        <field name="code">model._cron_reconcile_deliveries()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="False"/>
    </record>

    <record id="cron_ic_reconcile_invoices" model="ir.cron">
        <field name="name">Inter Cars: Reconcile Invoices</field>
        <field name="model_id" ref="model_ic_backend"/>
        <field name="state">code</field>
        <field name="code">model._cron_reconcile_invoices()</field>
        <field name="interval_number">6</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="False"/>
    </record>

</odoo>
