<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_warehouse_pallet" model="ir.sequence">
            <field name="name">Warehouse Pallet</field>
            <field name="code">warehouse.pallet</field>
            <field name="prefix">PLT-%(year)s-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_warehouse_checking_session" model="ir.sequence">
            <field name="name">Warehouse Checking Session</field>
            <field name="code">warehouse.checking.session</field>
            <field name="prefix">CHK-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_delivery_list_import" model="ir.sequence">
            <field name="name">Delivery List Import</field>
            <field name="code">delivery.list.import</field>
            <field name="prefix">DLI-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_dropship_import" model="ir.sequence">
            <field name="name">Dropship Import</field>
            <field name="code">dropship.import</field>
            <field name="prefix">DSI-%(year)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
