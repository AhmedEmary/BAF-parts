<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pallet_label" model="ir.actions.report">
        <field name="name">Pallet Label (QR)</field>
        <field name="model">warehouse.pallet</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">intelliwise_custom.report_pallet_label_template</field>
        <field name="report_file">intelliwise_custom.report_pallet_label_template</field>
        <field name="print_report_name">'Label - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_warehouse_pallet"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pallet_label_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <t t-foreach="docs" t-as="o">
                    <div class="page" style="font-family: Helvetica, Arial, sans-serif; page-break-inside: avoid;">
                        
                        <div style="border: 4px solid #000; width: 100%; background-color: white;">
                            
                            <div class="row" style="margin:0; border-bottom: 2px solid #000; padding: 15px;">
                                <div class="col-7">
                                    <img t-if="o.env.company.logo" 
                                         t-att-src="image_data_uri(o.env.company.logo)" 
                                         style="max-height: 60px; max-width: 100%;" alt="Logo"/>
                                </div>
                                <div class="col-5 text-end" style="padding-top: 5px;">
                                    <small style="color: #666; font-weight: bold; text-transform: uppercase;">Pallet ID</small>
                                    <div style="font-size: 24px; font-weight: 900; line-height: 1;">
                                        <span t-field="o.name"/>
                                    </div>
                                </div>
                            </div>

                            <div style="padding: 20px; border-bottom: 2px solid #000;">
                                <small style="color: #666; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">Ship To:</small>
                                <div style="font-size: 38px; font-weight: bold; line-height: 1.1; margin-top: 5px;">
                                    <span t-field="o.partner_id.name"/>
                                </div>
                                <div style="font-size: 18px; color: #333; margin-top: 5px;">
                                    <div t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></div>
                                    <div t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></div>
                                    <div>
                                        <span t-if="o.partner_id.city" t-field="o.partner_id.city"/>
                                        <span t-if="o.partner_id.state_id">, <span t-field="o.partner_id.state_id.code"/></span>
                                        <span t-if="o.partner_id.zip"> <span t-field="o.partner_id.zip"/></span>
                                    </div>
                                    <div t-if="o.partner_id.country_id"><span t-field="o.partner_id.country_id.name"/></div>
                                </div>
                            </div>

                            <div class="row" style="margin: 0; border-bottom: 2px solid #000;">
                                <div class="col-6" style="border-right: 2px solid #000; padding: 15px;">
                                    <small style="color: #666; font-weight: bold;">PACKING REF</small>
                                </div>
                                <div class="col-6" style="padding: 15px;">
                                    <small style="color: #666; font-weight: bold;">DATE</small>
                                    <div style="font-size: 20px; font-weight: bold;">
                                        <span t-field="o.ready_date"/>
                                    </div>
                                </div>
                            </div>

                            <div class="text-center" style="padding: 30px 20px;">
                                <img t-if="o.get_qr_code()" 
                                     t-att-src="'data:image/png;base64,%s' % o.get_qr_code()" 
                                     style="width: 250px; height: 250px; border: 1px solid #eee;" 
                                     alt="QR Code"/>
                                <div style="margin-top: 10px; font-weight: bold; font-size: 14px; letter-spacing: 2px;">SCAN FOR CONTENT</div>
                            </div>

                            <div style="border-top: 4px solid #000; background-color: white;">
                                <table class="table table-bordered mb-0" style="margin: 0; border: none;">
                                    <tr style="height: 60px;">
                                        <td class="text-center" style="width: 33%; vertical-align: middle; background-color: #f0f0f0;">
                                            <small style="font-weight: bold; color: #555;">WEIGHT</small><br/>
                                            <span style="font-size: 18px; font-weight: bold;"><span t-field="o.weight"/> kg</span>
                                        </td>
                                        <td class="text-center" style="width: 34%; vertical-align: middle;">
                                            <small style="font-weight: bold; color: #555;">DIMENSIONS</small><br/>
                                            <span style="font-size: 16px; font-weight: bold;">
                                                <span t-field="o.length"/>x<span t-field="o.width"/>x<span t-field="o.height"/> cm
                                            </span>
                                        </td>
                                        <td class="text-center" style="width: 33%; vertical-align: middle; background-color: #f0f0f0;">
                                            <small style="font-weight: bold; color: #555;">METHOD</small><br/>
                                            <span style="font-size: 18px; font-weight: bold; text-transform: uppercase;">
                                                <span t-field="o.shipment_method"/>
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
