<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_invoice_lines_form" model="ir.ui.view">
        <field name="name">import.invoice.lines.form</field>
        <field name="model">import.invoice.lines</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <p class="text-muted">
                    Columns required: <b>SKU, Qty, Price, SO Number</b>
                </p>
                <footer>
                    <button name="action_import" string="Import Lines" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_invoice_lines" model="ir.actions.act_window">
        <field name="name">Import Lines</field>
        <field name="res_model">import.invoice.lines</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_credit_note_wizard" model="ir.actions.act_window">
        <field name="name">Create Custom Credit Note</field>
        <field name="res_model">credit.note.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_move_form_inherit_intelliwise" model="ir.ui.view">
        <field name="name">account.move.form.inherit.intelliwise</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <div name="button_box" position="inside">
                <button name="action_view_pallets"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-cubes"
                        invisible="pallet_count == 0">
                    <field name="pallet_count" widget="statinfo" string="Pallets"/>
                </button>
            </div>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="is_down_payment_invoice"
                       invisible="move_type not in ('out_invoice', 'out_receipt')"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="%(action_credit_note_wizard)d" 
                        string="Create Custom Credit Note" 
                        type="action" 
                        class="btn-secondary"
                        invisible="state != 'posted' or move_type != 'out_invoice'"/>

                <button name="action_open_draw_down_payment"
                        string="Draw Down Payments"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft' or move_type != 'out_invoice'"/>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']" position="before">
                <button name="%(action_import_invoice_lines)d"
                        string="Import Lines from Excel"
                        type="action"
                        class="btn btn-secondary"
                        icon="fa-upload"
                        invisible="state != 'draft' or move_type != 'out_invoice'"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='name']" position="after">
                <field name="is_down_payment" column_invisible="1"/>
                <field name="supplier_delivery_ref" optional="show"/>
                <field name="origin_country_id" optional="hide"/>
                <field name="hs_code" optional="hide"/>
            </xpath>
        </field>
    </record>
    <record id="action_server_export_invoice_excel" model="ir.actions.server">
        <field name="name">Export to Excel</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_export_invoice_excel()
        </field>
    </record>

    <record id="action_down_payment_invoices_intelliwise" model="ir.actions.act_window">
        <field name="name">Down Payments</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('move_type', '=', 'out_invoice'), ('is_down_payment_invoice', '=', True)]</field>
        <field name="context">{'default_move_type': 'out_invoice', 'default_is_down_payment_invoice': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Down Payment Invoice!
            </p>
        </field>
    </record>

    <menuitem id="menu_down_payment_invoices"
              name="Down Payments"
              parent="account.menu_finance_receivables"
              action="action_down_payment_invoices_intelliwise"
              sequence="3"/>

</odoo>
