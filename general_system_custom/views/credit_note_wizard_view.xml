<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_credit_note_wizard_form" model="ir.ui.view">
        <field name="name">credit.note.wizard.form</field>
        <field name="model">credit.note.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Credit Note">
                <group>
                    <group>
                        <field name="reason" placeholder="e.g. Damaged Goods"/>
                        <field name="date"/>
                    </group>
                    <group>
                        <field name="journal_id"/>
                        <field name="invoice_id" invisible="1"/>
                    </group>
                </group>
                <div class="alert alert-info" role="status">
                    Select the items you wish to credit and adjust the quantity if needed.
                </div>
                <field name="line_ids">
                    <list editable="bottom" create="0" delete="0">
                        <field name="move_line_id" column_invisible="1"/>
                        
                        <field name="is_selected" widget="boolean_toggle"/>
                        <field name="product_id"/>
                        <field name="price_unit"/>
                        <field name="quantity" readonly="not is_selected"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_credit_note" string="Create Credit Note" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_credit_note_wizard" model="ir.actions.act_window">
        <field name="name">Create Custom Credit Note</field>
        <field name="res_model">credit.note.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
