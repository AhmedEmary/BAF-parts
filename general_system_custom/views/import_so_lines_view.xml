<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_so_lines_form" model="ir.ui.view">
        <field name="name">import.so.lines.form</field>
        <field name="model">import.so.lines</field>
        <field name="arch" type="xml">
            <form string="Import Lines">
                <group>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <div class="text-muted">
                    <p>Upload an Excel file with the following header columns:</p>
                    <ul>
                        <li><b>sku</b>: Product SKU</li>
                        <li><b>qty</b>: Quantity to order</li>
                        <li><b>brand</b> (optional): Brand name — required only when the same SKU exists for multiple brands</li>
                        <li><b>price</b> (optional): Overwrite Sale Price</li>
                    </ul>
                </div>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_so_lines" model="ir.actions.act_window">
        <field name="name">Import Lines</field>
        <field name="res_model">import.so.lines</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
