<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_so_lines_form" model="ir.ui.view">
        <field name="name">import.so.lines.form</field>
        <field name="model">import.so.lines</field>
        <field name="arch" type="xml">
            <form string="Import Lines">
                <field name="state" invisible="1"/>

                <group invisible="state != 'upload'">
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <div class="text-muted" invisible="state != 'upload'">
                    <p>Upload an Excel file. The importer detects columns automatically:</p>
                    <ul>
                        <li><b>SKU</b> — found by header (SKU, Code, Article, Reference…) or by content. Matches the product SKU or Internal Reference; a brand prefix like <i>BMW_12345</i> is recognised too.</li>
                        <li><b>Quantity</b> — found by header (Qty, Quantity, Menge…) or as a numeric column. Empty/missing quantity defaults to <b>1</b>.</li>
                        <li><b>Brand</b> (optional) — found by header or auto-detected from brand names in the data. Disambiguates SKUs shared by multiple brands.</li>
                        <li><b>Price</b> (optional) — header column (Price, Preis…); overrides the sale price.</li>
                    </ul>
                    <p>A file with no header row works too — the first column is taken as SKU and the second as quantity.</p>
                </div>

                <div class="alert alert-warning" role="alert" invisible="state != 'conflicts'">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    Some SKUs in your file exist for more than one brand. Pick the brand to use for each, then click <b>Continue Import</b>.
                </div>
                <field name="conflict_ids" invisible="state != 'conflicts'" nolabel="1">
                    <list editable="bottom" create="0" delete="0">
                        <field name="sku" readonly="1"/>
                        <field name="candidate_brand_ids" widget="many2many_tags" readonly="1" string="Available Brands"/>
                        <field name="brand_id" options="{'no_create': True, 'no_open': True}"/>
                    </list>
                </field>

                <footer>
                    <button name="action_import" string="Import"
                            type="object" class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button name="action_import" string="Continue Import"
                            type="object" class="btn-primary"
                            invisible="state != 'conflicts'"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_so_lines" model="ir.actions.act_window">
        <field name="name">Import Lines</field>
        <field name="res_model">import.so.lines</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
