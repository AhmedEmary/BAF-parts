<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_tree_inherit_contact_number" model="ir.ui.view">
        <field name="name">res.partner.list.inherit.baf.contact.number</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='avatar_128']" position="after">
                <field name="contact_number"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_inherit_trusted_vendor" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.baf</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='category_id']" position="after">
                <field name="contact_number"/>
            </xpath>

            <xpath expr="//field[@name='property_supplier_payment_term_id']" position="after">
                <field name="is_trusted_vendor"/>
            </xpath>

            <xpath expr="//page[@name='sales_purchases']" position="inside">
                <separator string="BAF Webshop &amp; Pricing"/>
                <group>
                    <group string="Pricing Groups">
                        <field name="sales_group_ids"
                               widget="many2many_tags"
                               domain="[('active','=',True)]"
                               help="At most one group per brand family. Leave empty for guest prices."/>
                        <field name="is_b2b_eu_vat" readonly="1"
                               help="Auto-detected from VAT number + EU country. Grants −5 % on JLR when no JLR group is assigned."/>
                    </group>
                    <group string="Webshop Brand Visibility">
                        <field name="visible_brand_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"
                               placeholder="Select allowed brands..."/>
                    </group>
                </group>
            </xpath>

            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Vendor Pricing" invisible="supplier_rank == 0">
                    <group>
                        <field name="baf_purchase_method"/>
                        <field name="baf_brand_ids" widget="many2many_tags"/>
                        <field name="baf_sb_surcharge_pct"
                               invisible="baf_purchase_method != 'matrix'"/>
                    </group>
                    <div invisible="not baf_purchase_method" class="mt-3">
                        <separator string="Import Pricing Data"/>
                        <div class="text-muted mb-2">
                            Download the template for the selected method, fill in your
                            data, then upload the file and click Import. Importing
                            replaces this vendor's existing pricing.
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <button name="action_download_pricing_template" type="object"
                                    string="Download Template" class="btn-secondary"
                                    icon="fa-download"/>
                            <field name="baf_pricing_filename" invisible="1"/>
                            <field name="baf_pricing_file" filename="baf_pricing_filename"
                                   nolabel="1" class="mb-0"/>
                            <button name="action_import_vendor_pricing_file" type="object"
                                    string="Import File" class="btn-primary" icon="fa-upload"
                                    invisible="not baf_pricing_file"/>
                        </div>
                    </div>
                    <field name="baf_purchase_line_ids" invisible="baf_purchase_method != 'matrix'">
                        <list editable="bottom">
                            <field name="column_key"/>
                            <field name="discount_code"/>
                            <field name="discount_pct"/>
                        </list>
                    </field>
                    <field name="baf_code_value_ids" invisible="baf_purchase_method != 'codes'">
                        <list editable="bottom">
                            <field name="code_id"/>
                            <field name="percentage"/>
                        </list>
                    </field>
                    <field name="baf_supplierinfo_ids" invisible="baf_purchase_method != 'direct'">
                        <list editable="bottom">
                            <field name="product_tmpl_id"/>
                            <field name="price"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
</odoo>