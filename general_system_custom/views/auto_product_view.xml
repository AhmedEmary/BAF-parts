<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_brand_form" model="ir.ui.view">
        <field name="name">product.brand.form</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="is_public"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_product_brand_tree" model="ir.ui.view">
        <field name="name">product.brand.tree</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="is_public" widget="boolean_toggle"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_product_brand" model="ir.actions.act_window">
        <field name="name">Product Brands</field>
        <field name="res_model">product.brand</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_product_brand"
              name="Product Brands"
              parent="sale.prod_config_main"
              action="action_product_brand"
              sequence="15"/>

    <!-- Task 11: SKU exact-match search filter for fast product lookup -->
    <record id="product_template_search_view_inherit_sku" model="ir.ui.view">
        <field name="name">product.template.search.sku</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="default_code" string="SKU (exact)" filter_domain="[('sku', '=', self)]"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_view_form_inherit_auto_product" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit.auto.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_policy']" position="after">
                <field name="brand" widget="many2one"/>
                <field name="origin" placeholder="Select origin country"/>
                <field name="hs_code" placeholder="Enter HS code"/>
            </xpath>
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="surcharge" widget="monetary"/>
            </xpath>
        </field>
    </record>
</odoo>
