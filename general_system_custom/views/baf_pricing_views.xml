<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         BAF Sales Group
    ═══════════════════════════════════════════════════════ -->

    <record id="baf_sales_group_view_list" model="ir.ui.view">
        <field name="name">baf.sales.group.list</field>
        <field name="model">baf.sales.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="family_id"/>
                <field name="pricing_method"/>
                <field name="markup_pct"/>
                <field name="group_column_suffix"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="baf_sales_group_view_form" model="ir.ui.view">
        <field name="name">baf.sales.group.form</field>
        <field name="model">baf.sales.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Group Identity">
                            <field name="name"/>
                            <field name="family_id"
                                   help="Leave empty to make this a fallback group that prices every brand."/>
                            <field name="active"/>
                        </group>
                        <group string="Pricing Method">
                            <field name="pricing_method"/>
                            <field name="markup_pct"
                                   invisible="pricing_method != 'markup_pct'"
                                   string="Markup % on purchase price"/>
                            <field name="group_column_suffix"
                                   invisible="pricing_method != 'table_lookup'"
                                   help="e.g. GR1, GR2, GR3, GR4, MOTO"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Customers in this group">
                            <field name="partner_ids"
                                   widget="many2many"
                                   options="{'no_quick_create': False}"
                                   context="{'default_customer_rank': 1}">
                                <list>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="country_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Discount Codes"
                              invisible="pricing_method != 'table_lookup'">
                            <field name="discount_line_ids"
                                   context="{'default_table_type': 'sales'}">
                                <list editable="bottom">
                                    <field name="column_key"/>
                                    <field name="discount_code"/>
                                    <field name="discount_pct" string="Discount %"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="baf_sales_group_action" model="ir.actions.act_window">
        <field name="name">Sales Pricing Groups</field>
        <field name="res_model">baf.sales.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         BAF Discount Lines
    ═══════════════════════════════════════════════════════ -->

    <record id="baf_discount_line_view_list" model="ir.ui.view">
        <field name="name">baf.discount.line.list</field>
        <field name="model">baf.discount.line</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="table_type"/>
                <field name="partner_id"/>
                <field name="group_id"/>
                <field name="column_key"/>
                <field name="discount_code"/>
                <field name="discount_pct" string="Discount %"/>
            </list>
        </field>
    </record>

    <record id="baf_discount_line_view_form" model="ir.ui.view">
        <field name="name">baf.discount.line.form</field>
        <field name="model">baf.discount.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="table_type"/>
                        <field name="group_id"/>
                        <field name="column_key"/>
                        <field name="discount_code"/>
                        <field name="discount_pct" string="Discount %"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<record id="baf_discount_line_view_search" model="ir.ui.view">
        <field name="name">baf.discount.line.search</field>
        <field name="model">baf.discount.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="group_id"/>
                <field name="column_key"/>
                <field name="discount_code"/>
                <filter string="Purchase" name="purchase" domain="[('table_type','=','purchase')]"/>
                <filter string="Sales" name="sales" domain="[('table_type','=','sales')]"/>

                <separator/>
                <filter string="Table Type" name="group_table_type" context="{'group_by':'table_type'}"/>
                <filter string="Sales Group" name="group_sales_group" context="{'group_by':'group_id'}"/>
                <filter string="Column Key" name="group_column_key" context="{'group_by':'column_key'}"/>
            </search>
        </field>
    </record>
    <record id="baf_discount_line_action" model="ir.actions.act_window">
        <field name="name">BAF Discount Table</field>
        <field name="res_model">baf.discount.line</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         BAF Brand Family
    ═══════════════════════════════════════════════════════ -->

    <record id="baf_brand_family_view_list" model="ir.ui.view">
        <field name="name">baf.brand.family.list</field>
        <field name="model">baf.brand.family</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="brand_count" string="Brands"/>
                <field name="brand_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="baf_brand_family_view_form" model="ir.ui.view">
        <field name="name">baf.brand.family.form</field>
        <field name="model">baf.brand.family</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="note"/>
                    </group>
                    <group string="Brands in this family">
                        <field name="brand_ids"
                               widget="many2many_tags"
                               nolabel="1"
                               colspan="2"
                               options="{'no_create': True}"
                               placeholder="Choose brands to put into this family..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="baf_brand_family_action" model="ir.actions.act_window">
        <field name="name">Brand Families</field>
        <field name="res_model">baf.brand.family</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Menu entries under Sales > Products
    ═══════════════════════════════════════════════════════ -->

    <menuitem
        id="baf_pricing_menu_root"
        name="BAF Pricing"
        parent="sale.product_menu_catalog"
        sequence="200"/>

    <menuitem
        id="baf_brand_family_menu"
        name="Brand Families"
        parent="baf_pricing_menu_root"
        action="baf_brand_family_action"
        sequence="5"/>

    <menuitem
        id="baf_sales_group_menu"
        name="Sales Pricing Groups"
        parent="baf_pricing_menu_root"
        action="baf_sales_group_action"
        sequence="10"/>

    <menuitem
        id="baf_discount_line_menu"
        name="Discount Table"
        parent="baf_pricing_menu_root"
        action="baf_discount_line_action"
        sequence="20"/>

    <!-- Also add Discount Table under Purchase menu -->
    <menuitem
        id="baf_discount_line_menu_purchase"
        name="BAF Discount Table"
        parent="purchase.menu_purchase_root"
        action="baf_discount_line_action"
        sequence="6"/>

    <!-- ═══════════════════════════════════════════════════════
         Extend res.partner form — add Sales Pricing Group field
    ═══════════════════════════════════════════════════════ -->

    <record id="view_partner_form_baf_sales_group" model="ir.ui.view">
        <field name="name">res.partner.form.baf.sales.group</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='property_supplier_payment_term_id']" position="after">
                <field name="sales_group_ids"
                       string="Sales Pricing Groups"
                       widget="many2many_tags"
                       options="{'no_quick_create': True}"
                       help="Leave empty → customer sees full UPE (MSRP). Assign at most one sales pricing group per brand family (for example one BMW/MINI group and one JLR group)."/>
            </xpath>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Extend product.template form — BAF Pricing tab
    ═══════════════════════════════════════════════════════ -->

    <record id="product_template_view_baf_pricing" model="ir.ui.view">
        <field name="name">product.template.form.baf.pricing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="BAF Pricing" name="baf_pricing">
                    <group string="BAF Discount">
                        <field name="baf_brand_family" readonly="1"/>
                        <field name="baf_discount_code"
                               string="Discount Code"/>
                        <field name="baf_column_key"
                               readonly="1"
                               string="Resolved Column Key"/>
                    </group>
                    <group string="BMW / MINI specifics">
                        <field name="baf_type_code" string="Type Code (1–9)"/>
                        <field name="baf_mod" string="Mod"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
