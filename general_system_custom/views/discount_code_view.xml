<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="discount_code_view_search" model="ir.ui.view">
        <field name="name">discount.code.view.search</field>
        <field name="model">discount.code</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_ids"/>
            </search>
        </field>
    </record>

    <record id="discount_code_view_form" model="ir.ui.view">
        <field name="name">discount.code.view.form</field>
        <field name="model">discount.code</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. MAS_L"/>
                    </group>
                    <notebook>
                        <page string="Supplier Percentages">
                            <field name="value_ids">
                                <list editable="bottom">
                                    <field name="partner_id"/>
                                    <field name="percentage"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="discount_code_view_tree" model="ir.ui.view">
        <field name="name">discount.code.view.tree</field>
        <field name="model">discount.code</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_ids" widget="many2many_tags" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="discount_code_action_window" model="ir.actions.act_window">
        <field name="name">Discount Codes</field>
        <field name="res_model">discount.code</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem 
        id="discount_code_menu_sale" 
        name="Discount Codes" 
        parent="sale.product_menu_catalog" 
        action="discount_code_action_window" 
        sequence="100"/>

    <menuitem 
        id="discount_code_menu_purchase" 
        name="Discount Codes" 
        parent="purchase.menu_purchase_root" 
        action="discount_code_action_window"
        sequence="5"/>
</odoo>