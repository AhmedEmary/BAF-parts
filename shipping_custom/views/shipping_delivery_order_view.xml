<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shipping_delivery_order_list" model="ir.ui.view">
        <field name="name">shipping.delivery.order.list</field>
        <field name="model">shipping.delivery.order</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'"
                  decoration-success="state == 'confirmed'"
                  decoration-danger="state == 'error'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="picking_id"/>
                <field name="provider_account_id"/>
                <field name="provider"/>
                <field name="service_name"/>
                <field name="freight_charge"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="tracking_number"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'error'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_shipping_delivery_order_search" model="ir.ui.view">
        <field name="name">shipping.delivery.order.search</field>
        <field name="model">shipping.delivery.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="picking_id"/>
                <field name="tracking_number"/>
                <field name="provider_account_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_error" string="Error" domain="[('state', '=', 'error')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                <filter name="group_provider" string="Provider" context="{'group_by': 'provider'}"/>
                <filter name="group_picking" string="Transfer" context="{'group_by': 'picking_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_shipping_delivery_order_form" model="ir.ui.view">
        <field name="name">shipping.delivery.order.form</field>
        <field name="model">shipping.delivery.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_preview_payload" type="object"
                            string="Preview Payload" class="btn-secondary"
                            invisible="state not in ('draft', 'error')"/>
                    <button name="action_generate_label" type="object"
                            string="Generate Label" class="btn-primary"
                            invisible="state not in ('draft', 'error')"
                            confirm="Submit this shipment to the carrier?"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft" class="btn-secondary"
                            invisible="state != 'error'"/>
                    <button name="action_cancel_order" type="object"
                            string="Cancel / Void" class="btn-danger"
                            invisible="state != 'confirmed'"
                            confirm="Void this shipment with the carrier?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_labels" type="object"
                                class="oe_stat_button" icon="fa-file-pdf-o"
                                invisible="label_count == 0">
                            <field name="label_count" widget="statinfo" string="Labels"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="picking_id" readonly="state != 'draft'"/>
                            <field name="provider_account_id" readonly="state != 'draft'"/>
                            <field name="provider" invisible="1"/>
                            <field name="service_type" readonly="state != 'draft'"/>
                            <field name="service_name"/>
                            <field name="label_format" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="freight_charge"/>
                            <field name="actual_charge"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="tracking_number"/>
                            <field name="planned_shipping_datetime" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Shipper" name="shipper">
                            <group>
                                <group>
                                    <field name="shipper_partner_id" readonly="state != 'draft'"/>
                                    <field name="shipper_name" readonly="state != 'draft'"/>
                                    <field name="shipper_company_name" readonly="state != 'draft'"/>
                                    <field name="shipper_phone" readonly="state != 'draft'"/>
                                    <field name="shipper_email" readonly="state != 'draft'"/>
                                </group>
                                <group>
                                    <field name="shipper_street" readonly="state != 'draft'"/>
                                    <field name="shipper_street2" readonly="state != 'draft'"/>
                                    <field name="shipper_city" readonly="state != 'draft'"/>
                                    <field name="shipper_zip" readonly="state != 'draft'"/>
                                    <field name="shipper_state_id" readonly="state != 'draft'"
                                           domain="[('country_id', '=', shipper_country_id)]"/>
                                    <field name="shipper_country_id" readonly="state != 'draft'"/>
                                </group>
                            </group>
                        </page>
                        <page string="Recipient" name="recipient">
                            <group>
                                <group>
                                    <field name="recipient_partner_id" readonly="state != 'draft'"/>
                                    <field name="recipient_name" readonly="state != 'draft'"/>
                                    <field name="recipient_company_name" readonly="state != 'draft'"/>
                                    <field name="recipient_phone" readonly="state != 'draft'"/>
                                    <field name="recipient_email" readonly="state != 'draft'"/>
                                </group>
                                <group>
                                    <field name="recipient_street" readonly="state != 'draft'"/>
                                    <field name="recipient_street2" readonly="state != 'draft'"/>
                                    <field name="recipient_city" readonly="state != 'draft'"/>
                                    <field name="recipient_zip" readonly="state != 'draft'"/>
                                    <field name="recipient_state_id" readonly="state != 'draft'"
                                           domain="[('country_id', '=', recipient_country_id)]"/>
                                    <field name="recipient_country_id" readonly="state != 'draft'"/>
                                </group>
                            </group>
                        </page>
                        <page string="Packages" name="packages">
                            <field name="package_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="package_type_id"/>
                                    <field name="name"/>
                                    <field name="weight"/>
                                    <field name="length"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Customs &amp; Options" name="customs">
                            <group>
                                <group>
                                    <field name="description" readonly="state != 'draft'"/>
                                    <field name="incoterm" readonly="state != 'draft'"/>
                                    <field name="pickup_requested" readonly="state != 'draft'"/>
                                </group>
                                <group>
                                    <field name="is_customs_declarable" readonly="state != 'draft'"/>
                                    <field name="declared_value" readonly="state != 'draft'"/>
                                    <field name="declared_value_currency_id" readonly="state != 'draft'"/>
                                </group>
                            </group>
                        </page>
                        <page string="API Log" name="api_log">
                            <field name="api_log_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="direction"/>
                                    <field name="method"/>
                                    <field name="endpoint"/>
                                    <field name="status_code"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="create_date"/>
                                                <field name="direction"/>
                                                <field name="method"/>
                                                <field name="endpoint"/>
                                                <field name="status_code"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Request Payload">
                                                <field name="payload" widget="text"/>
                                            </page>
                                            <page string="Response Body">
                                                <field name="response_body" widget="text"/>
                                            </page>
                                            <page string="Error" invisible="not error_message">
                                                <field name="error_message"/>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Last Payload / Response" name="last_payload">
                            <group>
                                <field name="last_request_payload" widget="text" readonly="1"/>
                                <field name="last_response_body" widget="text" readonly="1"/>
                            </group>
                        </page>
                        <page string="Error" name="error" invisible="not error_message">
                            <field name="error_message" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_shipping_delivery_order" model="ir.actions.act_window">
        <field name="name">Shipping Delivery Orders</field>
        <field name="res_model">shipping.delivery.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_shipping_delivery_order_search"/>
    </record>

    <menuitem id="menu_shipping_delivery_order_root"
              name="Shipping Orders"
              parent="stock.menu_stock_root"
              sequence="80"/>

    <menuitem id="menu_shipping_delivery_order"
              name="Delivery Orders"
              parent="menu_shipping_delivery_order_root"
              action="action_shipping_delivery_order"
              sequence="10"/>

</odoo>
