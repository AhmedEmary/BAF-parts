<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_baf_b2b_approved" model="mail.template">
        <field name="name">BAF B2B: Zugang freigeschaltet</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="subject">Ihr BAF Parts B2B-Zugang ist bereit</field>
        <field name="email_from">{{ (user.email_formatted or '') }}</field>
        <field name="email_to">{{ object.email or '' }}</field>
        <field name="partner_to">{{ object.id }}</field>
        <field name="lang">{{ object.lang or 'de_DE' }}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
<div style="margin:0;padding:0;font-family:Inter,Arial,sans-serif;background:#f7f7f7;">
    <table align="center" border="0" cellpadding="0" cellspacing="0" width="600" style="background:#ffffff;border:1px solid #d8d8d8;border-radius:18px;overflow:hidden;">
        <tr>
            <td style="padding:28px 32px;background:#000000;color:#ffffff;">
                <div style="font-size:11px;font-weight:900;letter-spacing:0.16em;text-transform:uppercase;color:#cfcfcf;">BAF Parts B2B</div>
                <div style="margin-top:8px;font-size:26px;font-weight:900;letter-spacing:-0.04em;">Ihr Zugang ist bereit</div>
            </td>
        </tr>
        <tr>
            <td style="padding:28px 32px;color:#000000;font-size:15px;line-height:1.55;font-weight:600;">
                <p style="margin:0 0 14px;">Guten Tag <t t-out="object.name or ''"/>,</p>
                <p style="margin:0 0 14px;">
                    wir haben Ihren B2B-Antrag geprüft und Ihren Zugang freigeschaltet.
                    Bitte schließen Sie die Registrierung über den folgenden Link ab und vergeben Sie Ihr Passwort.
                </p>
                <t t-set="signup_url" t-value="object._get_signup_url()"/>
                <p style="margin:24px 0;text-align:center;">
                    <a t-att-href="signup_url"
                       style="display:inline-block;background:#000000;color:#ffffff;border-radius:999px;padding:14px 28px;font-weight:900;font-size:15px;text-decoration:none;letter-spacing:-0.01em;">
                        Zugang aktivieren
                    </a>
                </p>
                <p style="margin:0 0 8px;font-size:13px;color:#555555;">
                    Falls der Button nicht funktioniert, kopieren Sie diesen Link in Ihren Browser:
                </p>
                <p style="margin:0 0 18px;font-size:12px;word-break:break-all;color:#004b7a;">
                    <a t-att-href="signup_url" t-out="signup_url or ''" style="color:#004b7a;"/>
                </p>
                <p style="margin:0 0 8px;">
                    Nach der Aktivierung können Sie über
                    <a href="/bestellsystem" style="color:#000000;font-weight:900;">/bestellsystem</a>
                    Teilenummern suchen und direkt in den Warenkorb legen.
                </p>
                <p style="margin:24px 0 0;color:#555555;font-size:13px;">
                    Bei Fragen erreichen Sie uns über das <a href="/contactus" style="color:#000000;">Kontaktformular</a>.
                </p>
                <p style="margin:18px 0 0;color:#000000;">Ihr BAF Parts Team</p>
            </td>
        </tr>
    </table>
</div>
        </field>
    </record>

</odoo>