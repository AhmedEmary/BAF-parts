<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_view_form_inherit_auto_product" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit.auto.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hs_code']" position="after">
                <field name="replaced_by_id" widget="many2one"/>
                <field name="sku"/>
                <field name="unit_of_sales"/>
            </xpath>
            <!-- Replace the native volume row: swap system UoM label for a fixed cm³ badge -->
            <xpath expr="//div[@name='volume']" position="replace">
                <div class="o_row" name="volume"
                     invisible="product_variant_count &gt; 1 and not is_product_variant">
                    <field name="volume" string="Volume" class="oe_inline" style="max-width: 7rem;"/>
                    <span class="o_field_widget oe_inline">cm³</span>
                </div>
            </xpath>

            <!-- Physical dimensions: each on its own labelled row inside the Logistics group -->
            <xpath expr="//group[@name='group_lots_and_weight']" position="inside">
                <label for="height"/>
                <div class="o_row">
                    <field name="height" class="oe_inline" style="max-width: 7rem;"/>
                    <span class="o_field_widget oe_inline">cm</span>
                </div>
                <label for="width"/>
                <div class="o_row">
                    <field name="width" class="oe_inline" style="max-width: 7rem;"/>
                    <span class="o_field_widget oe_inline">cm</span>
                </div>
                <label for="length"/>
                <div class="o_row">
                    <field name="length" class="oe_inline" style="max-width: 7rem;"/>
                    <span class="o_field_widget oe_inline">cm</span>
                </div>
            </xpath>
        </field>
    </record>

    <template id="product_custom_sku" inherit_id="website_sale.product_title">
        <xpath expr="//h1[@t-field='product.name']" position="after">
            <t t-set="is_nla" t-value="product.sku and product.sku.strip().upper() == 'NLA'"/>

            <div t-if="product.sku and not is_nla" class="mt-2 mb-2 text-muted" style="font-size: 1.1rem;">
                <strong>SKU:</strong> <span t-field="product.sku"/>
            </div>
            <div t-if="product.brand" class="mb-2 text-muted">
                <strong>Brand:</strong> <span t-field="product.brand.name"/>
            </div>

            <div t-if="is_nla" class="mb-3 py-2 px-3"
                 style="background-color: #fbeaea; border-left: 3px solid #c0392b; font-size: 1.05rem;">
                <span class="fw-bold text-uppercase" style="color: #c0392b; letter-spacing: 0.03em;">
                    <i class="fa fa-ban me-1"/> No Longer Available
                </span>
            </div>

            <div t-if="product.replaced_by_id" class="mb-3 py-2 ps-3"
                 style="border-left: 3px solid #6c757d; font-size: 1.05rem;">
                <div class="text-uppercase text-muted small fw-semibold" style="letter-spacing: 0.05em;">
                    <i class="fa fa-exchange me-1"/> New part number
                </div>
                <a t-att-href="product.replaced_by_id.website_url"
                   class="text-dark text-decoration-none fw-semibold"
                   style="border-bottom: 1px dotted #6c757d;">
                    <t t-out="product.replaced_by_id.name"/>
                    <t t-if="product.replaced_by_id.sku">
                        <span class="text-muted fw-normal ms-1">(<t t-out="product.replaced_by_id.sku"/>)</span>
                    </t>
                </a>
            </div>

            <table class="table table-sm mb-3" style="max-width: 380px; font-size: 1rem;">
                <tbody>
                    <tr>
                        <td class="text-muted py-1 border-0">List Price</td>
                        <td class="fw-semibold py-1 border-0 text-end">
                            <span t-esc="product.baf_website_display_price()"
                                  t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                        </td>
                    </tr>
                    <tr t-if="product.weight">
                        <td class="text-muted py-1 border-0">Weight</td>
                        <td class="fw-semibold py-1 border-0 text-end">
                            <t t-out="product.weight"/> kg
                        </td>
                    </tr>
                    <tr t-if="product.height">
                        <td class="text-muted py-1 border-0">Height</td>
                        <td class="fw-semibold py-1 border-0 text-end">
                            <t t-out="product.height"/> cm
                        </td>
                    </tr>
                    <tr t-if="product.width">
                        <td class="text-muted py-1 border-0">Width</td>
                        <td class="fw-semibold py-1 border-0 text-end">
                            <t t-out="product.width"/> cm
                        </td>
                    </tr>
                    <tr t-if="product.length">
                        <td class="text-muted py-1 border-0">Length</td>
                        <td class="fw-semibold py-1 border-0 text-end">
                            <t t-out="product.length"/> cm
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted py-1 border-0">Shipment Type</td>
                        <td class="fw-semibold py-1 border-0 text-end">
                            <span t-if="product.is_bulky_goods">Bulky Goods</span>
                            <span t-else="">Standard</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </xpath>
    </template>

    <template id="products_item_custom_sku" inherit_id="website_sale.products_item">
        <xpath expr="//h2[hasclass('o_wsale_products_item_title')]" position="after">
            <t t-set="is_nla" t-value="product.replaced_by_id.sku and product.replaced_by_id.sku.strip().upper() == 'NLA'"/>

            <div t-if="product.brand or (product.sku and not is_nla)" class="mb-1 text-muted small">
                <span t-if="product.brand"><strong t-out="product.brand.name"/> - </span>
                <span t-if="product.sku and not is_nla">SKU: <t t-out="product.sku"/></span>
            </div>

            <div class="mb-2 small">
                <span t-if="is_nla" class="fw-bold" style="color: #c0392b;">
                    <i class="fa fa-ban me-1"/> No Longer Available
                </span>
                <t t-else="">
                    <t t-set="is_in_stock" t-value="product.sudo().qty_available &gt; 0"/>
                    <span t-if="is_in_stock" class="text-success fw-bold">IN STOCK</span>
                    <span t-else="" class="fw-bold" style="color: #fd7e14;">TO ORDER</span>
                </t>
            </div>
        </xpath>
    </template>

   <template id="one_hybrid_custom_sku_brand" inherit_id="website.one_hybrid">
        <xpath expr="//div[hasclass('o_search_result_item_detail')]/div[1]" position="replace">
            <div t-att-class="'h6 fw-bold %s' % ('' if description else 'mb-0')">
                <t t-set="is_product" t-value="result.get('website_url', '').startswith('/shop/')"/>
                <t t-out="result['name']"/>

                <t t-if="is_product">
                    <t t-set="clean_url" t-value="result.get('website_url', '').split('?')[0]"/>
                    <t t-set="prod_id_str" t-value="clean_url.split('-')[-1]"/>

                    <t t-if="prod_id_str.isdigit()">
                        <t t-set="prod" t-value="request.env['product.template'].sudo().browse(int(prod_id_str))"/>
                        <t t-if="prod.exists()">
                            <t t-if="prod.brand">
                                - <span class="text-primary"><t t-out="prod.brand.name"/></span> -
                            </t>
                            <t t-set="display_sku" t-value="prod.sku or prod.default_code"/>
                            <t t-if="display_sku">
                                <span class="text-muted"><t t-out="display_sku"/></span>
                            </t>
                        </t>
                    </t>
                </t>
            </div>
        </xpath>
    </template>
  <template id="custom_header_search_to_shop" inherit_id="website.website_search_box">
        
        <xpath expr="//t[@t-set='search_placeholder']" position="replace">
            <t t-set="search_placeholder">Search products...</t>
        </xpath>

        <xpath expr="//input[@name='search']" position="attributes">
            <attribute name="data-search-type">products</attribute>
        </xpath>

        <xpath expr="//div[@role='search']" position="after">
            <script type="text/javascript">
                document.addEventListener("DOMContentLoaded", function() {
                    var searchForms = document.querySelectorAll('form.o_searchbar_form');

                    searchForms.forEach(function(form) {
                        form.setAttribute('action', '/shop');
                        var input = form.querySelector('input[name="search"]');
                        if (input) {
                            input.setAttribute('data-search-type', 'products');
                        }
                    });
                });
            </script>
        </xpath>
        
    </template>
</odoo>
