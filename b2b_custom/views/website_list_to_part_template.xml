<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="list_to_part_page" name="List to Part">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="row">
                    <div class="col-12">
                        <h1>Bulk Order (List to Part)</h1>
                        <p class="text-muted">
                            Paste your Excel data below.<br/>
                            <strong>Format:</strong> Brand [TAB] Part Number [TAB] Quantity
                        </p>
                        <form action="/b2b/list-to-part/search" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="form-group mb-3">
                                <textarea name="bulk_input" class="form-control" rows="15" 
                                          placeholder="Maserati    311401    100&#10;Ferrari     123456    5"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fa fa-search"/> Search Parts
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

   <template id="list_to_part_results">
    <t t-call="website.layout">
        
        <style>
            #custom_loading_overlay {
                display: none; /* Hidden by default */
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(255, 255, 255, 0.85);
                z-index: 9999;
                align-items: center;
                justify-content: center;
                flex-direction: column;
                backdrop-filter: blur(2px);
            }
            .spinner-loader {
                width: 60px;
                height: 60px;
                border: 6px solid #f3f3f3;
                border-top: 6px solid #71639e; /* Odoo Purple */
                border-radius: 50%;
                animation: spin 1s linear infinite;
                margin-bottom: 20px;
            }
            @keyframes spin {
                0% { transform: rotate(0deg); }
                100% { transform: rotate(360deg); }
            }
        </style>

        <div id="custom_loading_overlay">
            <div class="spinner-loader"></div>
            <h3 class="text-muted">Processing your order...</h3>
            <p>Please do not close this window.</p>
        </div>

        <div class="container mt-4">
            
            <div class="alert alert-success">
                Found <strong t-esc="pager['total'] * 50"/> items. 
                Page <span t-esc="pager['current']"/> of <span t-esc="pager['total']"/>.
            </div>

            <form method="POST">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="bulk_input" t-att-value="original_input"/>
                
                <div class="d-flex justify-content-end mb-3 gap-2">
                    <button type="submit" formaction="/b2b/list-to-part/export" class="btn btn-outline-success">
                        <i class="fa fa-file-excel-o"/> Extract Excel
                    </button>
                    
                    <button type="submit" 
                            formaction="/b2b/list-to-part/add_all" 
                            class="btn btn-success"
                            onclick="document.getElementById('custom_loading_overlay').style.display = 'flex';">
                        <i class="fa fa-shopping-cart"/> Add ALL to Cart
                    </button>
                </div>

                <div class="d-flex justify-content-between mb-2">
                     <button t-if="pager['has_prev']" type="submit" formaction="/b2b/list-to-part/search" name="page" t-att-value="pager['current'] - 1" class="btn btn-secondary">&lt; Previous</button>
                     <button t-else="" disabled="disabled" class="btn btn-secondary opacity-50">&lt; Previous</button>
                     <span>Page <t t-esc="pager['current']"/> / <t t-esc="pager['total']"/></span>
                     <button t-if="pager['has_next']" type="submit" formaction="/b2b/list-to-part/search" name="page" t-att-value="pager['current'] + 1" class="btn btn-primary">Next &gt;</button>
                     <button t-else="" disabled="disabled" class="btn btn-primary opacity-50">Next &gt;</button>
                </div>

                <table class="table table-striped table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Brand</th>
                            <th>SKU</th>
                            <th>Name</th>
                            <th>MOQ (Unit)</th>
                            <th class="text-end">Price</th>
                            <th>Note</th>
                            <th class="text-center">Qty</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="results" t-as="line" t-att-class="'table-secondary text-muted' if line.get('blocked') else ''">
                            <td><span t-esc="line['brand']"/></td>
                            <td><span t-esc="line['sku']"/></td>
                            <td>
                                <a t-att-href="'/shop/product/%s' % line['product'].id" target="_blank">
                                    <span t-esc="line['name']"/>
                                </a>
                            </td>
                            <td>
                                <span t-esc="line['moq']"/>
                                <small class="text-muted">(<span t-esc="line['uom']"/>)</small>
                            </td>
                            <td class="text-end">
                                <span t-esc="line['price']"
                                    t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                            </td>
                            <td>
                                <span t-if="line.get('blocked')" class="badge bg-danger" t-esc="line['block_note']"/>
                                <input t-else="" type="text" class="form-control form-control-sm" placeholder="..."/>
                            </td>
                            <td class="text-center">
                                <span t-if="line.get('blocked')" class="badge bg-secondary">—</span>
                                <span t-else="" class="badge bg-primary" t-esc="line['qty']"/>
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <div class="d-flex justify-content-center mt-3">
                    <button t-if="pager['has_next']" type="submit" formaction="/b2b/list-to-part/search" name="page" t-att-value="pager['current'] + 1" class="btn btn-primary">
                        Next Page &gt;
                    </button>
                </div>
            </form>
            
            <div t-if="not_found" class="mt-5 text-muted">
                <h3>Not Found Items</h3>
                <ul>
                    <li t-foreach="not_found" t-as="nf">
                        <t t-esc="nf['brand']"/> - <t t-esc="nf['sku']"/>
                    </li>
                </ul>
            </div>
            
        </div>
    </t>
</template>




</odoo>
