<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_custom_discounts" model="ir.ui.view">
      <field name="name">sale.order.form.inherit.auto.sale</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list//field[@name='price_unit']" position="before">
               <field name="retail_price"/>
                <field name="surcharge"/>
                <field name="baf_applied_column_key" optional="show"/>
                <field name="baf_applied_discount_pct" string="Disc %" optional="show"/>
                <field name="baf_line_note" string="Notiz" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>