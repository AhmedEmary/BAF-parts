<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mass_vendor_price_import_form" model="ir.ui.view">
        <field name="name">mass.vendor.price.import.form</field>
        <field name="model">mass.vendor.price.import</field>
        <field name="arch" type="xml">
            <form string="Mass Vendor Price Import">

                <field name="state" invisible="1"/>

                <div invisible="state != 'upload'">
                    <div class="bg-light border border-info rounded p-3 mb-3" style="font-size: 13px;">
                        <h4 class="text-info mb-2">
                            <i class="fa fa-info-circle" title="Info"/> User Guide: Mass Vendor Price Import
                        </h4>
                        <p>This tool creates or updates vendor (supplier) prices for existing products at high speed. Upload a <b>.CSV</b> or <b>.XLSX</b> file to begin mapping your columns.</p>

                        <hr class="border-info"/>
                        <h5 class="mb-1"><strong>Important Rules</strong></h5>
                        <ul class="mb-0">
                            <li><strong>Vendor:</strong> Select the supplier these prices belong to. It is applied to every row.</li>
                            <li><strong>Required fields:</strong> Your file MUST contain a <strong>SKU</strong>, a <strong>Brand</strong> and a <strong>Price</strong> column.</li>
                            <li><strong>Existing products only:</strong> Rows whose product (Brand prefix + SKU) does not already exist are skipped.</li>
                            <li><strong>Re-import safe:</strong> Existing prices from this vendor for the matched products are replaced.</li>
                        </ul>
                    </div>

                    <group>
                        <field name="file_data"
                               filename="file_name"
                               widget="binary"
                               options="{'accepted_file_extensions': '.csv,.xlsx'}"
                               required="state == 'upload'"/>
                        <field name="file_name" invisible="1"/>
                        <field name="vendor_id" required="state == 'upload'"/>
                    </group>
                </div>

                <div invisible="state != 'mapping'">
                    <div class="bg-light border border-warning rounded p-3 mb-3">
                        <span class="text-warning fw-bold"><i class="fa fa-list-alt" title="Map Columns"/> Map your columns:</span> The system has guessed the mapping based on your headers. Please verify and assign the correct Odoo Field to each column. Leave columns you don't want to import blank.
                    </div>

                    <field name="mapping_ids">
                        <list editable="bottom" create="0" delete="0">
                            <field name="column_index" readonly="1" force_save="1" column_invisible="True"/>
                            <field name="file_column_name" readonly="1" force_save="1"/>
                            <field name="field_name"/>
                        </list>
                    </field>
                </div>

                <footer>
                    <button name="action_read_headers"
                            string="Read File Headers"
                            type="object"
                            class="btn-primary"
                            icon="fa-arrow-right"
                            invisible="state != 'upload'"/>

                    <button name="action_import"
                            string="Confirm &amp; Import Now"
                            type="object"
                            class="btn-danger"
                            icon="fa-upload"
                            invisible="state != 'mapping'"
                            confirm="MASS IMPORT WARNING: You are about to import thousands of vendor prices. Once you click OK, the screen will freeze. Please DO NOT refresh the page. Do you want to proceed?"/>

                    <button name="action_reset"
                            string="Back to Upload"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'mapping'"/>

                    <button string="Cancel" class="btn-secondary" special="cancel" icon="fa-times"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mass_vendor_price_import" model="ir.actions.act_window">
        <field name="name">Mass Vendor Price Import</field>
        <field name="res_model">mass.vendor.price.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_mass_vendor_price_import"
              name="Mass Vendor Price Import"
              parent="sale.prod_config_main"
              action="action_mass_vendor_price_import"
              sequence="100"/>
</odoo>
