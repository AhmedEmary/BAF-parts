<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_website_form_ic_toggle" model="ir.ui.view">
        <field name="name">website.form.ic.toggle</field>
        <field name="model">website</field>
        <field name="inherit_id" ref="website.view_website_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Inter Cars Aftermarket">
                    <field name="enable_aftermarket_search"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
